{
    "version": 2,
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/index.py" },
        { "src": "/service-worker.js", "dest": "/frontend/build/service-worker.js" },
        { "src": "/manifest.json", "dest": "/frontend/build/manifest.json" },
        { "src": "/static/(.*)", "dest": "/frontend/build/static/$1" },
        { "src": "/(.*\\.(js|css|png|jpg|jpeg|svg|ico|txt|json|woff2?))", "dest": "/frontend/build/$1" },
        { "src": "/(.*)", "dest": "/frontend/build/index.html" }
    ]
}
